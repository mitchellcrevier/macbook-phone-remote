<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mitchellcrevier.macremote</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/Developer/CommandLineTools/Library/Frameworks/Python3.framework/Versions/3.9/Resources/Python.app/Contents/MacOS/Python</string>
        <string>-m</string>
        <string>gunicorn</string>
        <string>-w</string>
        <string>1</string>
        <string>--threads</string>
        <string>100</string>
        <string>-b</string>
        <string>0.0.0.0:5050</string>
        <string>--chdir</string>
        <string>SCRIPT_DIR</string>
        <string>app:app</string>
    </array>
    <key>WorkingDirectory</key>
    <string>SCRIPT_DIR</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>SCRIPT_DIR/server.log</string>
    <key>StandardErrorPath</key>
    <string>SCRIPT_DIR/server.log</string>
</dict>
</plist>
